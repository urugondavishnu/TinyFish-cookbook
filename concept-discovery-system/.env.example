# TinyFish API Key (Required)
# Get your API key from: https://tinyfish.ai
VITE_TINYFISH_API_KEY=your_tinyfish_api_key_here

# GitHub Personal Access Token (Optional - for higher rate limits)
# Without token: 60 requests/hour
# With token: 5000 requests/hour
# Create token at: https://github.com/settings/tokens
VITE_GITHUB_TOKEN=your_github_token_here

# OpenRouter API Key (Optional - for AI-powered query generation)
# Without key: uses deterministic keyword extraction (still works, less targeted)
# With key: LLM generates smarter, more relevant search queries
# Get your key at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Stack Exchange API Key (Optional - for higher rate limits)
# Without key: 300 requests/day
# With key: 10,000 requests/day
# Register at: https://stackapps.com/apps/oauth/register
VITE_STACKEXCHANGE_KEY=your_stackexchange_key_here
